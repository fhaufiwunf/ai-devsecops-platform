      ],
      "id": "1db1e02d-6015-4251-b563-13806b2c747a",
      "name": "Validate Input"
    },
    {
      "parameters": {
        "jsCode": "const f = $json.finding || {};\n\nconst prompt = `\nYou are an AI DevSecOps remediation assistant.\n\nVulnerability:\n- Finding ID: ${$json.finding_id}\n- Tool: ${f.tool || \"\"}\n- Severity: ${f.severity || \"\"}\n- Type: ${f.type || \"\"}\n- Title: ${f.title || \"\"}\n- File or URL: ${f.file_or_url || \"\"}\n- Line: ${f.line || \"\"}\n- Suggested fix from scanner: ${f.suggested_fix || \"\"}\n\nSource code context:\n${$json.source_context || \"No source code context provided.\"}\n\nDeveloper question:\n${$json.question}\n\nPlease answer with:\n1. Root cause\n2. Security impact\n3. Step-by-step fix\n4. Secure code example if possible\n5. How to verify the fix\n`;\n\nreturn [{\n  json: {\n    ...$json,\n    ai_prompt: prompt\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "032dcec7-8d8e-4123-a193-59c63ba11011",
      "name": "Build AI Chat Prompt"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://192.168.0.101:11434/api/generate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  {\n    model: \"qwen2.5:3b\",\n    prompt: $json.ai_prompt,\n    stream: false,\n    options: {\n      temperature: 0.2,\n      num_predict: 700\n    }\n  }\n}}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
