    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\n\nreturn [{\n  json: {\n    finding_id: body.finding_id,\n    question: body.question || \"How do I fix this vulnerability?\",\n    finding: body.finding || {},\n    source_context: body.source_context || \"\"\n  }\n}];"
      },
