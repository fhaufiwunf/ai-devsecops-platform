      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const previous = $('Build AI Chat Prompt').first().json;\n\nconst answer =\n  $json.body?.response ||\n  $json.response ||\n  \"\";\n\nreturn [{\n  json: {\n    finding_id: previous.finding_id,\n    question: previous.question,\n    answer,\n    created_at: new Date().toISOString()\n  }\n}];"
      },
